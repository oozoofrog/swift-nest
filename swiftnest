#!/bin/sh
set -eu

SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd -P)
TOOL_ROOT="$SCRIPT_DIR/tools/swiftnest-cli"
BUILD_ROOT="$TOOL_ROOT/.build"
BUILD_LOCK_DIR="$BUILD_ROOT/.swiftnest-build.lock"
BUILD_LOCK_PID_FILE="$BUILD_LOCK_DIR/pid"
BUILD_LOCK_HELD=0

resolve_lang() {
  explicit_lang=""
  pending_lang_value=0

  for arg in "$@"; do
    if [ "$pending_lang_value" -eq 1 ]; then
      explicit_lang=$arg
      pending_lang_value=0
      continue
    fi

    case "$arg" in
      --lang)
        pending_lang_value=1
        ;;
      --lang=*)
        explicit_lang=${arg#--lang=}
        ;;
    esac
  done

  for candidate in "$explicit_lang" "${SWIFTNEST_LANG:-}" "${LC_ALL:-}" "${LC_MESSAGES:-}" "${LANG:-}"; do
    case "$candidate" in
      [Kk][Oo]|[Kk][Oo]_*|[Kk][Oo]-*)
        printf 'ko'
        return 0
        ;;
      [Ee][Nn]|[Ee][Nn]_*|[Ee][Nn]-*)
        printf 'en'
        return 0
        ;;
    esac
  done

  printf 'en'
}

localized_wrapper_swift_required() {
  case "$(resolve_lang "$@")" in
    ko)
      printf '%s\n' '오류: macOS에서 SwiftNest CLI를 빌드하려면 swift가 필요합니다.'
      ;;
    *)
      printf '%s\n' 'error: swift is required to build the SwiftNest CLI on macOS.'
      ;;
  esac
}

if ! command -v swift >/dev/null 2>&1; then
  localized_wrapper_swift_required "$@" >&2
  exit 1
fi

find_binary() {
  for candidate in \
    "$TOOL_ROOT/.build/release/swiftnest" \
    "$TOOL_ROOT/.build/arm64-apple-macosx/release/swiftnest" \
    "$TOOL_ROOT/.build/x86_64-apple-macosx/release/swiftnest"
  do
    if [ -x "$candidate" ]; then
      printf '%s\n' "$candidate"
      return 0
    fi
  done

  found=$(find "$TOOL_ROOT/.build" -type f -path '*/release/swiftnest' -print 2>/dev/null | head -n 1 || true)
  if [ -n "$found" ]; then
    printf '%s\n' "$found"
    return 0
  fi

  return 1
}

needs_build() {
  binary_path=$1
  if [ ! -x "$binary_path" ]; then
    return 0
  fi

  if find "$TOOL_ROOT/Package.swift" "$TOOL_ROOT/Sources" -type f -newer "$binary_path" -print -quit 2>/dev/null | grep -q .; then
    return 0
  fi

  return 1
}

resolve_build_jobs() {
  build_jobs=${SWIFTNEST_BUILD_JOBS:-1}
  case "$build_jobs" in
    ""|*[!0-9]*)
      printf "%s\n" 1
      return 0
      ;;
  esac

  while [ "${build_jobs#0}" != "$build_jobs" ]; do
    build_jobs=${build_jobs#0}
  done

  if [ -z "$build_jobs" ] || [ "$build_jobs" -lt 1 ] 2>/dev/null; then
    printf "%s\n" 1
    return 0
  fi

  printf "%s\n" "$build_jobs"
}

BINARY_PATH=$(find_binary || true)
if [ -z "${BINARY_PATH:-}" ] || needs_build "$BINARY_PATH"; then
  cleanup_build_lock() {
    if [ "${BUILD_LOCK_HELD:-0}" -ne 1 ]; then
      return 0
    fi
    rm -f "$BUILD_LOCK_PID_FILE"
    rmdir "$BUILD_LOCK_DIR" 2>/dev/null || true
    BUILD_LOCK_HELD=0
  }

  acquire_build_lock() {
    wait_without_pid=0
    mkdir -p "$BUILD_ROOT"

    while ! mkdir "$BUILD_LOCK_DIR" 2>/dev/null; do
      if [ -f "$BUILD_LOCK_PID_FILE" ]; then
        lock_pid=$(head -n 1 "$BUILD_LOCK_PID_FILE" 2>/dev/null || true)
        case "$lock_pid" in
          ""|*[!0-9]*)
            rm -f "$BUILD_LOCK_PID_FILE"
            rmdir "$BUILD_LOCK_DIR" 2>/dev/null || true
            wait_without_pid=0
            continue
            ;;
        esac

        if ! kill -0 "$lock_pid" 2>/dev/null; then
          rm -f "$BUILD_LOCK_PID_FILE"
          rmdir "$BUILD_LOCK_DIR" 2>/dev/null || true
          wait_without_pid=0
          continue
        fi
      else
        wait_without_pid=$((wait_without_pid + 1))
        if [ "$wait_without_pid" -ge 5 ]; then
          rmdir "$BUILD_LOCK_DIR" 2>/dev/null || true
          wait_without_pid=0
          continue
        fi
      fi

      sleep 0.2
    done

    printf '%s\n' "$$" > "$BUILD_LOCK_PID_FILE"
    BUILD_LOCK_HELD=1
    trap 'cleanup_build_lock' EXIT HUP INT TERM
  }

  release_build_lock() {
    cleanup_build_lock
    trap - EXIT HUP INT TERM
  }

  acquire_build_lock
  BINARY_PATH=$(find_binary || true)
  if [ -z "${BINARY_PATH:-}" ] || needs_build "$BINARY_PATH"; then
    BUILD_JOBS=$(resolve_build_jobs)
    BUILD_LOG=$(mktemp "${TMPDIR:-/tmp}/swiftnest-build.XXXXXX")
    if ! swift build --package-path "$TOOL_ROOT" -c release --jobs "$BUILD_JOBS" --product swiftnest >"$BUILD_LOG" 2>&1; then
      cat "$BUILD_LOG" >&2
      rm -f "$BUILD_LOG"
      exit 1
    fi
    rm -f "$BUILD_LOG"
    BINARY_PATH=$(find_binary)
  fi
  release_build_lock
fi

export SWIFTNEST_ASSET_ROOT="$SCRIPT_DIR"
export SWIFTNEST_ROOT="$SCRIPT_DIR"
export HARNESS_ROOT="$SCRIPT_DIR"
exec "$BINARY_PATH" "$@"
