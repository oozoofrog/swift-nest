#!/bin/sh
set -eu

SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd -P)
TOOL_ROOT="$SCRIPT_DIR/tools/swiftnest-cli"

if ! command -v swift >/dev/null 2>&1; then
  echo "error: swift is required to build the SwiftNest CLI on macOS." >&2
  exit 1
fi

find_binary() {
  for candidate in \
    "$TOOL_ROOT/.build/release/swiftnest" \
    "$TOOL_ROOT/.build/arm64-apple-macosx/release/swiftnest" \
    "$TOOL_ROOT/.build/x86_64-apple-macosx/release/swiftnest"
  do
    if [ -x "$candidate" ]; then
      printf '%s\n' "$candidate"
      return 0
    fi
  done

  found=$(find "$TOOL_ROOT/.build" -type f -path '*/release/swiftnest' -print 2>/dev/null | head -n 1 || true)
  if [ -n "$found" ]; then
    printf '%s\n' "$found"
    return 0
  fi

  return 1
}

needs_build() {
  binary_path=$1
  if [ ! -x "$binary_path" ]; then
    return 0
  fi

  if find "$TOOL_ROOT/Package.swift" "$TOOL_ROOT/Sources" -type f -newer "$binary_path" -print -quit 2>/dev/null | grep -q .; then
    return 0
  fi

  return 1
}

BINARY_PATH=$(find_binary || true)
if [ -z "${BINARY_PATH:-}" ] || needs_build "$BINARY_PATH"; then
  swift build --package-path "$TOOL_ROOT" -c release --product swiftnest >/dev/null
  BINARY_PATH=$(find_binary)
fi

export SWIFTNEST_ROOT="$SCRIPT_DIR"
export HARNESS_ROOT="$SCRIPT_DIR"
exec "$BINARY_PATH" "$@"
